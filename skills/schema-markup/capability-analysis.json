      "id": "implement-json-ld-schema",
      "description": "Generate correct JSON-LD structured data markup for web pages (Organization, Article, Product, FAQPage, HowTo, BreadcrumbList, LocalBusiness, Event, SoftwareApplication) following schema.org vocabulary and Google guidelines.",
      "current_path": {
        "primitives": [
          {
            "id": "gen.text.structured",
            "min_level": "L2",
            "evidence": "JSON-LD output is nested JSON (1-5KB range) with @context, @type, @graph, nested objects for author/publisher/offers/aggregateRating. Multiple schema types combined via @graph array."
          },
          {
            "id": "gen.code.html",
            "min_level": "L2",
            "evidence": "Schema must be placed in <script type=\"application/ld+json\"> tags in HTML <head> or end of <body>. Next.js implementation uses dangerouslySetInnerHTML."
          },
          {
            "id": "follow.format",
            "min_level": "L2",
            "evidence": "Output must conform to schema.org vocabulary with exact property names (@type, @context, @id, mainEntity), correct value types (ISO 8601 dates, fully qualified URLs, schema.org enumerations)."
          }
        ]
      },
