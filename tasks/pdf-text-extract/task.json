{
  "id": "pdf-text-extract",
  "name": "Extract structured data from a PDF report",
  "category": "nano-pdf",
  "gradingType": "automated",
  "prompt": "Read report.pdf (a 2-page quarterly sales report) and extract its contents into report_data.json with: (1) title: the report title, (2) period: the reporting period (e.g., 'Q4 2025'), (3) financials: object with total_revenue (number), operating_expenses (number), net_profit (number), and profit_margin (number, as percentage like 25.7), (4) highlights: array of key highlight strings, (5) regions: array of objects with name, revenue (number), and growth (number, as percentage), (6) total_pages: number of pages in the PDF.",
  "timeoutMs": 300000,
  "maxSteps": 30,
  "eval": [
