{
  "database": {
    "host": "db.example.com",
    "port": 5432,
    "name": "myapp",
    "pool": { "min": 5, "max": 20, "idle": 10000 }
  },
  "cache": {
    "provider": "redis",
    "host": "cache.example.com",
    "port": 6379,
    "ttl": 3600,
    "prefix": "app:"
  },
  "logging": {
    "level": "info",
    "format": "json",
    "outputs": ["stdout", "file"],
    "file": "/var/log/app.log",
    "rotation": { "maxSize": "100m", "maxFiles": 10, "compress": true }
  },
  "security": {
    "cors": { "origins": ["https://example.com", "https://app.example.com"], "methods": ["GET", "POST", "PUT", "DELETE"] },
    "rateLimit": { "window": 900000, "max": 100 },
    "helmet": true
  },
  "features": {
    "darkMode": true,
    "betaUsers": false,
    "analytics": true,
    "experimentalApi": false,
    "maxUploadSize": "50mb"
  }
}
